VITE_API_URL=http://localhost:3001/api/v1
VITE_DEFAULT_MODEL=gpt-4o-mini
# نماد اعتماد الکترونیکی (enamad.ir) — id و Code را از پنل enamad بردارید
VITE_ENAMAD_ID=
VITE_ENAMAD_CODE=
# فیچرفلگ ویجت ربات فروش (صفحه‌ی اصلی + قیمت‌گذاری) — false برای مخفی‌کردن، هر مقدار دیگر یا خالی = فعال
VITE_SALES_BOT_ENABLED=true
# فیچرفلگ آمار «کاربر فعال»/«درصد رضایت» در بخش StatsBar لندینگ — true برای نمایش، هر مقدار دیگر یا خالی = مخفی
VITE_LANDING_STATS_ENABLED=false
# Microsoft Clarity (heatmap/session-recording) — Project ID را از داشبورد clarity.microsoft.com بردارید، خالی = غیرفعال
VITE_CLARITY_PROJECT_ID=
# سرویس مجزای event tracking/funnel (events-backend) — خالی = ایونت‌تراکینگ غیرفعال
VITE_EVENTS_API_URL=http://localhost:3002
VITE_EVENTS_WRITE_KEY=dev-write-key
