# ─── مرحله build ────────────────────────────────────────────
FROM node:22-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

# متغیرهای Vite در زمان build خونده می‌شن — اگر توی پنل دارکوب
# مقدار دیگه‌ای ست کردی، همون جایگزین این default‌ها می‌شه
ARG VITE_API_URL=https://api.nivoai.ir/api/v1
ARG VITE_DEFAULT_MODEL=gpt-4o-mini
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_DEFAULT_MODEL=$VITE_DEFAULT_MODEL

RUN npm run build

# ─── مرحله serve ────────────────────────────────────────────
FROM nginx:1.27-alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.spa.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
