# ─── مرحله build ────────────────────────────────────────────
FROM node:22-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

# متغیرهای Vite فقط در زمان build خونده می‌شن (import.meta.env، نه process.env runtime).
# دارکوب مقدار پنل «Environment Variables» رو به این build-arg ها نمی‌رسونه (تست شده،
# مقدار واقعی پنل هیچ‌وقت جایگزین این default ها نشد) — پس این‌جا مقدار واقعی پروداکشن
# مستقیم هاردکد شده، نه یک default قابل override. برای عوض‌کردن مقدار، همین‌جا ویرایش کن.
ARG VITE_API_URL=https://api.nivoai.ir/api/v1
ARG VITE_DEFAULT_MODEL=gpt-4o-mini
ARG VITE_ENAMAD_ID=754112
ARG VITE_ENAMAD_CODE=MT002yEUVg7doisGMOlOBj3tH7ilN1St
ARG VITE_SALES_BOT_ENABLED=true
ARG VITE_LANDING_STATS_ENABLED=false
ARG VITE_CLARITY_PROJECT_ID=xou800w32d
ARG VITE_EVENTS_API_URL=https://event.nivoai.ir
ARG VITE_EVENTS_WRITE_KEY=my-test-ASD!@#$%^nvnasdasdfasdfkljweiqma
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_DEFAULT_MODEL=$VITE_DEFAULT_MODEL
ENV VITE_ENAMAD_ID=$VITE_ENAMAD_ID
ENV VITE_ENAMAD_CODE=$VITE_ENAMAD_CODE
ENV VITE_SALES_BOT_ENABLED=$VITE_SALES_BOT_ENABLED
ENV VITE_LANDING_STATS_ENABLED=$VITE_LANDING_STATS_ENABLED
ENV VITE_CLARITY_PROJECT_ID=$VITE_CLARITY_PROJECT_ID
ENV VITE_EVENTS_API_URL=$VITE_EVENTS_API_URL
ENV VITE_EVENTS_WRITE_KEY=$VITE_EVENTS_WRITE_KEY

RUN npm run build

# ─── مرحله serve ────────────────────────────────────────────
FROM nginx:1.27-alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.spa.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
